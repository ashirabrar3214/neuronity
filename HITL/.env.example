# ═══════════════════════════════════════════════════════
#  HITL Steering Engine — Configuration
# ═══════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────
GEMINI_API_KEY=your-api-key-here
GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# ── User Knobs ────────────────────────────────────────
# How often should the AI stop for your input?
#   1 = rarely (let it run)   10 = frequently (tight leash)
INTERVENTION_LEVEL=5

# Your domain expertise level
#   1 = beginner   10 = expert
EXPERTISE_LEVEL=5

# Hard cap on agent turns before forcing a stop
MAX_TURNS=30

# ── Logging ───────────────────────────────────────────
LOG_FILE=logs/session.jsonl

# ── Advanced (PID tuning) ─────────────────────────────
# Uncomment to override the auto-calculated values.
# PID_KP=1.25
# PID_KI=0.35
# PID_KD=0.55
# HYSTERESIS_UPPER=0.70
# HYSTERESIS_LOWER=0.40
